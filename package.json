{
  "name": "finvastra-pulse",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:app": "cross-env VITE_USE_EMULATOR=true tsx server.ts",
    "dev:emulators": "firebase emulators:start --only auth,firestore --import ./emulator-data --export-on-exit ./emulator-data",
    "seed:emulator": "tsx scripts/seed/seedEmployees.ts",
    "seed:production": "tsx scripts/seed/seedProductionEmployees.ts",
    "import:employees": "tsx scripts/seed/importEmployeesFromSheet.ts",
    "import:employees:dry": "cross-env DRY_RUN=true tsx scripts/seed/importEmployeesFromSheet.ts",
    "cleanup:duplicates": "tsx scripts/seed/cleanupDuplicates.ts",
    "migrate:profiles": "tsx scripts/seed/migrateProfileDocs.ts",
    "fix:ajay-role": "tsx scripts/seed/fixAjayRole.ts",
    "sync:holidays": "tsx scripts/seed/syncHolidays2026.ts",
    "kill:emulators": "npx kill-port 8080 9099 4000 4400 4500 9150 || true",
    "start": "node server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "build:prod": "tsc --noEmit && vite build",
    "deploy": "npm run build:prod && firebase target:apply hosting pulse gen-lang-client-0643641184 && firebase deploy --only hosting",
    "test:email": "tsx scripts/test/testSmtp.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cookie-parser": "^1.4.10",
    "@types/nodemailer": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.8",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "firebase-tools": "^15.18.0",
    "kill-port": "^2.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
