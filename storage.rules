rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── HR Letters ───────────────────────────────────────────────────────────
    //
    // Writes go through POST /api/admin/hr-letters/upload (server endpoint).
    // The Admin SDK bypasses these rules, so the write rule here is never
    // reached for normal use. Setting it to `if false` prevents any rogue
    // direct client upload.
    //
    // Reads use token-based download URLs generated server-side, so the read
    // rule is also only reached when accessing the object directly (not via URL).
    // We keep it for defence-in-depth: employee reads their own, admin reads all.
    match /hr-letters/{employeeId}/{fileName} {
      allow read: if request.auth != null && (
        request.auth.uid == employeeId
        || request.auth.token.role == 'admin'
        || request.auth.token.isHrmsManager == true
      );
      allow write: if false; // server-only (Admin SDK)
    }

    // Letters for employees without a Pulse account — stored under _manual/.
    // Admin reads only; no direct client write.
    match /hr-letters/_manual/{fileName} {
      allow read: if request.auth != null && (
        request.auth.token.role == 'admin'
        || request.auth.token.isHrmsManager == true
      );
      allow write: if false; // server-only (Admin SDK)
    }

    // ─── CRM Document Vault ───────────────────────────────────────────────────
    //
    // Opportunity-level attachments (bank statements, ITR, ID proof, etc.).
    // Uploads go through POST /api/crm/documents/upload (Admin SDK) so write is
    // set to false here.  Reads: admin or any user with CRM access (token claim).
    // Token-based download URLs bypass these rules entirely for direct downloads.
    match /crm-documents/{opportunityId}/{fileName} {
      allow read: if request.auth != null && (
        request.auth.token.role == 'admin'
        || request.auth.token.crmAccess == true
      );
      allow write: if false; // server-only (Admin SDK)
    }

    // ─── Company Documents ────────────────────────────────────────────────────
    // All employees can read (policies, handbooks, circulars).
    // Only admin / HR manager can upload. Relies on custom claims.
    match /company-documents/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.role == 'admin'
        || request.auth.token.isHrmsManager == true
      );
    }

    // ─── Employee Documents ───────────────────────────────────────────────────
    // Employee reads their own documents; admin / HR reads all.
    match /employee-documents/{employeeId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == employeeId
        || request.auth.token.role == 'admin'
        || request.auth.token.isHrmsManager == true
      );
      allow write: if request.auth != null && (
        request.auth.token.role == 'admin'
        || request.auth.token.isHrmsManager == true
      );
    }

    // ─── Claim receipts / bills ───────────────────────────────────────────────
    // Employee uploads their OWN bill (image/PDF), capped at 10 MB. Owner + HR/admin
    // can read. Images are compressed client-side before upload.
    match /claim-receipts/{employeeId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == employeeId
        || request.auth.token.role == 'admin'
        || request.auth.token.isHrmsManager == true
      );
      allow write: if request.auth != null
        && request.auth.uid == employeeId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // ─── Profile photos (avatars) ─────────────────────────────────────────────
    // Employee uploads their OWN avatar. Compressed client-side to a ~256px JPEG
    // (~15-30 KB) before upload; the 300 KB cap is a hard backstop. Readable by
    // all signed-in users — avatars render across shells, org chart and presence.
    match /profile-photos/{employeeId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == employeeId
        && request.resource.size < 300 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ─── Data Import audit files ──────────────────────────────────────────────
    // Original uploaded files stored as audit trail. Admin-write, Admin-read only.
    match /imports/{importType}/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.token.role == 'admin';
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // ─── CRM 2.0 client vault (PLAN.md Phase 3) ──────────────────────────────
    // Upload-once-reference-everywhere: case docTracker rows point at these
    // files by vaultDocId. Uploads go through POST /api/crm2/clients/:id/vault
    // (Admin SDK) — direct client writes denied. Reads: admins or holders of a
    // Pipeline case/lead read key (perms custom claim, synced by sync-claims).
    match /clients/{clientId}/vault/{vaultDocId} {
      allow read: if request.auth != null && (
        request.auth.token.role == 'admin'
        || request.auth.token.get('perms', {}).get('crm.cases.read', false) == true
        || request.auth.token.get('perms', {}).get('crm.leads.read', false) == true
      );
      allow write: if false; // server-only (Admin SDK)
    }

    // ─── Default deny ─────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
