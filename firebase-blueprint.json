{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "User information and settings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "employeeId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "department": { "type": "string" },
        "designation": { "type": "string" },
        "managerId": { "type": "string" },
        "joiningDate": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "hasCalendarAccess": { "type": "boolean" },
        "hrmsAccess": { "type": "boolean", "description": "Grants access to the HRMS module. Defaults to true for all employees." },
        "crmAccess": { "type": "boolean", "description": "Grants access to the CRM module. Default false; set true for RMs by admin." },
        "misAccess": { "type": "boolean", "description": "Grants access to the MIS module. Default false; set true for finance/accounts team by admin. Phase 4 build." },
        "crmRole": {
          "type": ["string", "null"],
          "enum": ["admin", "lead_generator", "lead_convertor", "manager", null],
          "description": "CRM functional role. lead_generator sources leads; lead_convertor closes them. Admin sets this field only."
        },
        "convertorVertical": {
          "type": ["string", "null"],
          "enum": ["loan", "wealth", "insurance", null],
          "description": "Only set when crmRole === 'lead_convertor'. Drives handoff matching so an opportunity is transferred to the correct specialist."
        },
        "isHrmsManager": {
          "type": "boolean",
          "description": "Grants leave approval and admin attendance override in HRMS. Set by admin only."
        }
      },
      "required": ["userId", "email", "role"]
    },
    "attendance": {
      "title": "Attendance Record",
      "description": "Daily attendance entry per employee. checkIn/checkOut are Firestore Timestamps (server-side). Phase 3 schema.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "checkIn": { "type": ["object", "null"], "description": "Firestore Timestamp or null" },
        "checkOut": { "type": ["object", "null"], "description": "Firestore Timestamp or null" },
        "workingHours": { "type": "number" },
        "status": { "type": "string", "enum": ["present", "half_day", "absent", "leave", "holiday"] },
        "markedBy": { "type": "string", "enum": ["self", "admin"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "object", "description": "Firestore serverTimestamp()" },
        "updatedAt": { "type": "object", "description": "Firestore serverTimestamp()" }
      },
      "required": ["userId", "date", "status", "markedBy", "createdAt", "updatedAt"]
    },
    "leave_application": {
      "title": "Leave Application",
      "description": "Employee leave application. Replaces Phase 1 /leaves collection. Phase 3 schema.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "type": { "type": "string", "enum": ["casual", "sick", "earned", "lop", "optional"] },
        "fromDate": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "toDate": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "days": { "type": "number", "description": "Working days (weekends + holidays excluded)" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "cancelled"] },
        "appliedAt": { "type": "object", "description": "Firestore serverTimestamp()" },
        "approvedBy": { "type": ["string", "null"] },
        "approvedAt": { "type": ["object", "null"], "description": "Firestore Timestamp or null" },
        "rejectionReason": { "type": ["string", "null"] },
        "calendarEventId": { "type": ["string", "null"] }
      },
      "required": ["employeeId", "type", "fromDate", "toDate", "days", "reason", "status", "appliedAt"]
    },
    "leave_balance": {
      "title": "Leave Balance",
      "description": "Annual leave balance per employee. Doc ID = employeeId. Written by admin/Cloud Function.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "year": { "type": "number" },
        "casual": {
          "type": "object",
          "properties": {
            "total": { "type": "number" },
            "used": { "type": "number" },
            "remaining": { "type": "number" }
          },
          "required": ["total", "used", "remaining"]
        },
        "sick": {
          "type": "object",
          "properties": {
            "total": { "type": "number" },
            "used": { "type": "number" },
            "remaining": { "type": "number" }
          },
          "required": ["total", "used", "remaining"]
        },
        "earned": {
          "type": "object",
          "properties": {
            "total": { "type": "number" },
            "used": { "type": "number" },
            "remaining": { "type": "number" }
          },
          "required": ["total", "used", "remaining"]
        }
      },
      "required": ["employeeId", "year", "casual", "sick", "earned"]
    },
    "holiday": {
      "title": "Holiday",
      "description": "Public and company holidays for a given year. Readable by all authenticated users.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["national", "regional", "optional"] },
        "year": { "type": "number" }
      },
      "required": ["date", "name", "type", "year"]
    },
    "payslip": {
      "title": "Payslip",
      "description": "Monthly payslip generated by admin from CA-provided salary data. Read-only for employees. Phase 3 schema.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "month": { "type": "string", "description": "YYYY-MM" },
        "basicSalary": { "type": "number" },
        "hra": { "type": "number" },
        "conveyanceAllowance": { "type": "number" },
        "medicalAllowance": { "type": "number" },
        "otherAllowances": { "type": "number" },
        "totalEarnings": { "type": "number" },
        "pf": { "type": "number" },
        "professionalTax": { "type": "number" },
        "tds": { "type": "number" },
        "otherDeductions": { "type": "number" },
        "totalDeductions": { "type": "number" },
        "netPay": { "type": "number" },
        "workingDays": { "type": "number" },
        "presentDays": { "type": "number" },
        "lopDays": { "type": "number" },
        "generatedAt": { "type": "object", "description": "Firestore serverTimestamp()" },
        "generatedBy": { "type": "string", "description": "UID of admin who generated this payslip" },
        "notes": { "type": "string" }
      },
      "required": ["employeeId", "month", "basicSalary", "totalEarnings", "totalDeductions", "netPay", "workingDays", "presentDays", "lopDays", "generatedAt", "generatedBy"]
    },
    "commission_statement": {
      "title": "Commission Statement",
      "description": "Actual commission payment received from a provider (bank/AMC/insurer). MIS-only. Phase 4.1.",
      "type": "object",
      "properties": {
        "providerId": { "type": "string" },
        "source": { "type": "string", "enum": ["bank", "amc", "insurer"] },
        "periodStart": { "type": "string", "description": "YYYY-MM" },
        "periodEnd": { "type": "string", "description": "YYYY-MM" },
        "statementDate": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "receivedDate": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "fileName": { "type": "string" },
        "fileUploadedAt": { "type": "object", "description": "Firestore Timestamp" },
        "totalAmount": { "type": "number" },
        "lineCount": { "type": "number" },
        "matchedCount": { "type": "number" },
        "discrepancyCount": { "type": "number" },
        "unmatchedCount": { "type": "number" },
        "status": { "type": "string", "enum": ["imported", "reconciling", "reconciled", "discrepancy", "closed"] },
        "importedBy": { "type": "string" },
        "importedAt": { "type": "object", "description": "Firestore serverTimestamp()" },
        "closedBy": { "type": ["string", "null"] },
        "closedAt": { "type": ["object", "null"] },
        "notes": { "type": "string" }
      },
      "required": ["providerId", "source", "periodStart", "periodEnd", "statementDate", "receivedDate", "fileName", "totalAmount", "lineCount", "status", "importedBy", "importedAt"]
    },
    "statement_line": {
      "title": "Statement Line",
      "description": "A single line item within a commission statement, linked to a commission_record after reconciliation. Phase 4.2.",
      "type": "object",
      "properties": {
        "statementId": { "type": "string" },
        "providerId": { "type": "string" },
        "rawDate": { "type": "string" },
        "rawDescription": { "type": "string" },
        "rawAmount": { "type": "string" },
        "parsedDate": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "parsedAmount": { "type": "number" },
        "matchedCommissionRecordId": { "type": ["string", "null"] },
        "matchedOpportunityId": { "type": ["string", "null"] },
        "discrepancyAmount": { "type": ["number", "null"] },
        "status": { "type": "string", "enum": ["unmatched", "matched", "discrepancy", "unknown", "excluded"] },
        "reconciledBy": { "type": ["string", "null"] },
        "reconciledAt": { "type": ["object", "null"] },
        "notes": { "type": "string" }
      },
      "required": ["statementId", "providerId", "rawDate", "rawDescription", "rawAmount", "parsedDate", "parsedAmount", "status"]
    },
    "rm_payout_slab": {
      "title": "RM Payout Slab",
      "description": "Defines the percentage of received commission paid out to an RM or role. Phase 4.3.",
      "type": "object",
      "properties": {
        "targetType": { "type": "string", "enum": ["user", "role"] },
        "targetId": { "type": "string", "description": "userId OR crmRole value (e.g. lead_convertor)" },
        "businessLine": { "type": "string", "enum": ["loan", "wealth", "insurance"] },
        "percentage": { "type": "number", "minimum": 0, "maximum": 100 },
        "effectiveFrom": { "type": "string", "format": "date" },
        "effectiveTo": { "type": ["string", "null"], "format": "date" },
        "active": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "object", "description": "Firestore serverTimestamp()" }
      },
      "required": ["targetType", "targetId", "businessLine", "percentage", "effectiveFrom", "active", "createdBy", "createdAt"]
    },
    "rm_payout": {
      "title": "RM Payout",
      "description": "Monthly payout record for a single RM, calculated from received commissions. Phase 4.3.",
      "type": "object",
      "properties": {
        "rmId": { "type": "string" },
        "rmDisplayName": { "type": "string" },
        "periodStart": { "type": "string", "description": "YYYY-MM" },
        "periodEnd": { "type": "string", "description": "YYYY-MM" },
        "lineItems": { "type": "array", "description": "Array of RmPayoutLineItem objects" },
        "totalReceivedBase": { "type": "number" },
        "totalPayout": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "approved", "paid"] },
        "generatedAt": { "type": "object", "description": "Firestore serverTimestamp()" },
        "generatedBy": { "type": "string" },
        "approvedBy": { "type": ["string", "null"] },
        "approvedAt": { "type": ["object", "null"] },
        "paidAt": { "type": ["object", "null"] },
        "paymentReference": { "type": ["string", "null"] },
        "paymentNotes": { "type": ["string", "null"] }
      },
      "required": ["rmId", "rmDisplayName", "periodStart", "periodEnd", "lineItems", "totalReceivedBase", "totalPayout", "status", "generatedAt", "generatedBy"]
    },
    "case": {
      "title": "Case (CRM 2.0)",
      "description": "A loan/wealth/insurance case in the CRM 2.0 pipeline. Collection /cases/{FIN-CASE-YYYY-####}. SERVER-ONLY writes — every mutation goes through /api/crm2/* and the Firestore write rule is false. Money economics are doc-split into the gated private/payout sub-doc. All people fields store FAPL-xxx employee codes. Stages 1-3 are case-level (CaseLevelStage); from Stage 4 each LOGIN sub-doc runs its own sanction/disbursement/payout. Authoritative type: src/types/crm2.ts (Crm2Case).",
      "type": "object",
      "properties": {
        "clientId": { "type": "string", "description": "FCL-/CL- client id (clients collection)" },
        "leadId": { "type": ["string", "null"], "description": "source lead id if converted, else null" },
        "productId": { "type": "string" },
        "handlingRm": { "type": "string", "description": "FAPL-xxx owner" },
        "collaborators": { "type": "array", "items": { "type": "string" }, "description": "Phase 6 — FAPL-xxx RMs sharing the case besides handlingRm" },
        "subDsaId": { "type": ["string", "null"], "description": "Connector (subDsas/SDSA-###) — per-login payout sub-agent" },
        "channelPartnerId": { "type": ["string", "null"], "description": "Sub DSA (HRMS connectors/FAC-###) sourcing partner — attribution + auto-payout" },
        "channelPartnerCode": { "type": ["string", "null"] },
        "channelPartnerName": { "type": ["string", "null"] },
        "lenderId": { "type": ["string", "null"] },
        "connectorId": { "type": ["string", "null"], "description": "Aggregator (aggregators/CONN-###) — Routed Via" },
        "mappingId": { "type": ["string", "null"], "description": "frozen DSA-code mapping id (set at disbursement)" },
        "slabId": { "type": ["string", "null"], "description": "frozen payout slab id" },
        "dsaCode": { "type": ["string", "null"] },
        "connectorCaseRef": { "type": ["string", "null"] },
        "bankApplicationNo": { "type": ["string", "null"] },
        "loanAccountNo": { "type": ["string", "null"] },
        "amountRequested": { "type": "number" },
        "amountSanctioned": { "type": ["number", "null"] },
        "amountDisbursed": { "type": ["number", "null"], "description": "server-written at disbursement" },
        "roiPct": { "type": ["number", "null"] },
        "tenureMonths": { "type": ["number", "null"] },
        "processingFee": { "type": ["number", "null"] },
        "disbursalCity": { "type": ["string", "null"] },
        "disbursalState": { "type": ["string", "null"] },
        "stage": { "type": "string", "enum": ["OPENED", "BASIC_DOCS", "DOCS", "IN_PROGRESS", "COMPLETED", "CLOSED"], "description": "case-level stage (CaseLevelStage); legacy CaseStage values tolerated on pre-cutover docs" },
        "outcome": { "type": ["string", "null"], "enum": ["COMPLETED", "REJECTED", "WITHDRAWN", null] },
        "rejectionReason": { "type": ["string", "null"] },
        "keyDates": { "type": "object", "description": "server-stamped Timestamps: opened, docsComplete, login, sanction, disbursement, pddCleared, otcCleared, closed" },
        "bankContact": { "type": ["object", "null"], "description": "{ name, email, mobile }" },
        "pddStatus": { "type": "string", "enum": ["NA", "PENDING", "PARTIAL", "CLEARED"] },
        "otcStatus": { "type": "string", "enum": ["NA", "PENDING", "CLEARED"] },
        "pddPendingList": { "type": "array", "items": { "type": "string" } },
        "queryLog": { "type": "array", "description": "{ raisedAt, detail, resolvedAt } entries" },
        "payoutStatus": { "type": "string", "description": "server-written badge mirrored from the payout cycle; NOT_DUE until disbursed" },
        "payoutCycleId": { "type": ["string", "null"] },
        "stage1": { "type": ["object", "null"], "description": "Stage-1 (Opened) underwriting: property, 3-yr turnover, GST turnover, income, existingLoans[], references[], notes" },
        "docsCompletePct": { "type": "number", "description": "server-maintained from docTracker" },
        "nextAction": { "type": ["string", "null"] },
        "remarks": { "type": ["string", "null"] },
        "wealth": { "type": ["object", "null"], "description": "wealth add-on (schema reserved)" },
        "insurance": { "type": ["object", "null"], "description": "insurance add-on (schema reserved)" },
        "createdAt": { "type": "object", "description": "Firestore serverTimestamp()" },
        "createdBy": { "type": "string", "description": "FAPL-xxx" },
        "updatedAt": { "type": "object" },
        "updatedBy": { "type": "string", "description": "FAPL-xxx" }
      },
      "required": ["clientId", "productId", "handlingRm", "amountRequested", "stage", "keyDates", "docsCompletePct", "createdAt", "createdBy"]
    },
    "case_applicant": {
      "title": "Case Applicant (CRM 2.0)",
      "description": "/cases/{caseId}/applicants/{applicantId}. PAN stored as an AES-256-GCM EncryptedField (panEnc + panLast4); Aadhaar last-4 ONLY (12-digit input rejected at the API). Server-only writes.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["PRIMARY", "CO_APPLICANT", "GUARANTOR"] },
        "relationshipToPrimary": { "type": "string", "enum": ["SELF", "SPOUSE", "FATHER", "MOTHER", "PARTNER", "DIRECTOR", "OTHER"] },
        "name": { "type": "string" },
        "panEnc": { "type": ["object", "null"], "description": "AES-256-GCM EncryptedField" },
        "panLast4": { "type": ["string", "null"] },
        "aadhaarLast4": { "type": ["string", "null"], "description": "last 4 digits ONLY — never the full number" },
        "dob": { "type": ["object", "null"] },
        "mobile": { "type": "string" },
        "email": { "type": ["string", "null"] },
        "address": { "type": ["object", "null"] },
        "occupation": { "type": ["string", "null"] },
        "incomeMonthly": { "type": ["number", "null"] },
        "cibil": { "type": ["object", "null"], "description": "{ score, pulledAt }" },
        "createdAt": { "type": "object" }, "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" }, "updatedBy": { "type": "string" }
      },
      "required": ["type", "name", "mobile"]
    },
    "case_doc_tracker": {
      "title": "Case Document Tracker Row (CRM 2.0)",
      "description": "/cases/{caseId}/docTracker/{rowId}. One row per required document per applicant; references a client vault doc by id (never copies the file). Server-only writes.",
      "type": "object",
      "properties": {
        "documentDefId": { "type": "string" },
        "applicantId": { "type": ["string", "null"], "description": "null = entity-level" },
        "requiredByStage": { "type": "string", "enum": ["LOGIN", "SANCTION", "DISBURSEMENT", "PDD"] },
        "status": { "type": "string", "enum": ["PENDING", "REQUESTED", "RECEIVED", "VERIFIED", "REJECTED_REUPLOAD", "EXPIRED"] },
        "vaultDocId": { "type": ["string", "null"] },
        "requestedAt": { "type": ["object", "null"] },
        "receivedAt": { "type": ["object", "null"] },
        "verifiedBy": { "type": ["string", "null"], "description": "FAPL-xxx" },
        "remarks": { "type": ["string", "null"] },
        "createdAt": { "type": "object" }, "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" }, "updatedBy": { "type": "string" }
      },
      "required": ["documentDefId", "requiredByStage", "status"]
    },
    "case_stage_history": {
      "title": "Case Stage History (CRM 2.0)",
      "description": "/cases/{caseId}/stageHistory/{entryId}. Append-only audit of every stage transition. Server-only writes.",
      "type": "object",
      "properties": {
        "from": { "type": ["string", "null"] },
        "to": { "type": "string" },
        "at": { "type": "object" },
        "by": { "type": "string", "description": "FAPL-xxx" },
        "note": { "type": ["string", "null"] }
      },
      "required": ["to", "at", "by"]
    },
    "case_login": {
      "title": "Case Login (CRM 2.0 per-login pipeline)",
      "description": "/cases/{caseId}/logins/{LGN-YYYY-####}. One login = one file submitted to one bank/NBFC. From Stage 4 each login runs its own progression (FILE_LOGIN -> CODE_LOGIN_DONE -> IN_PROCESS -> SANCTIONED -> DISBURSED -> PDD_OTC -> COMPLETED) and, at disbursement, creates its OWN payout cycle + MIS record. Server-only writes; stage/keyDates/money fields are protected. Authoritative type: src/types/crm2.ts (Login).",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "seq": { "type": "number", "description": "display order within the case (1,2,3...)" },
        "lenderId": { "type": ["string", "null"] },
        "connectorId": { "type": ["string", "null"], "description": "aggregator routed-via (defaults from the case)" },
        "subDsaId": { "type": ["string", "null"], "description": "Connector/SDSA- (defaults from the case)" },
        "channelPartnerId": { "type": ["string", "null"], "description": "Sub DSA/FAC- sourcing partner (defaults from the case)" },
        "channelPartnerCode": { "type": ["string", "null"] },
        "channelPartnerName": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "amountRequested": { "type": ["number", "null"] },
        "smName": { "type": ["string", "null"] }, "smNumber": { "type": ["string", "null"] },
        "asmName": { "type": ["string", "null"] }, "asmNumber": { "type": ["string", "null"] },
        "docsSent": { "type": "boolean" },
        "directFromBank": { "type": "boolean", "description": "structure now; payout-routing logic later" },
        "dsaCodeUsed": { "type": ["string", "null"], "enum": ["finvastra", "connector_own", null] },
        "codeName": { "type": ["string", "null"] },
        "loginDone": { "type": "boolean" },
        "loanApplicationNo": { "type": ["string", "null"] },
        "queryLog": { "type": "array" },
        "subProcesses": { "type": "object", "description": "In-Process parallel sub-processes: pd, technical, valuation, legal, credit — each { status, query, remarks }" },
        "amountSanctioned": { "type": ["number", "null"] },
        "roiPct": { "type": ["number", "null"] }, "tenureMonths": { "type": ["number", "null"] },
        "processingFee": { "type": ["number", "null"] }, "insuranceAmount": { "type": ["number", "null"] }, "otherCharges": { "type": ["number", "null"] },
        "sanctionDate": { "type": ["object", "null"] }, "sanctionLetterPath": { "type": ["string", "null"] }, "verifiedAppNo": { "type": ["string", "null"] },
        "customerDecision": { "type": ["string", "null"], "enum": ["ACCEPTED", "PENDING", "REJECTED", null] },
        "amountDisbursed": { "type": ["number", "null"] }, "disbursementDate": { "type": ["object", "null"] }, "loanAccountNo": { "type": ["string", "null"] },
        "disbursalCity": { "type": ["string", "null"] }, "disbursalState": { "type": ["string", "null"] },
        "bt": { "type": ["object", "null"], "description": "Balance Transfer { isBt, amount, date, mode, kind }" },
        "secured": { "type": ["object", "null"], "description": "{ isSecured, modtDate, agreementDate, mode }" },
        "pddStatus": { "type": "string", "enum": ["NA", "PENDING", "PARTIAL", "CLEARED"] },
        "otcStatus": { "type": "string", "enum": ["NA", "PENDING", "CLEARED"] },
        "pddPendingList": { "type": "array", "items": { "type": "string" } },
        "payoutStatus": { "type": "string", "description": "per-login payout badge; NOT_DUE until disbursed" },
        "payoutCycleId": { "type": ["string", "null"] },
        "mappingId": { "type": ["string", "null"] }, "slabId": { "type": ["string", "null"] }, "dsaCode": { "type": ["string", "null"] },
        "stage": { "type": "string", "enum": ["FILE_LOGIN", "CODE_LOGIN_DONE", "IN_PROCESS", "SANCTIONED", "DISBURSED", "PDD_OTC", "COMPLETED"] },
        "outcome": { "type": ["string", "null"], "enum": ["COMPLETED", "REJECTED", "WITHDRAWN", null] },
        "rejectionReason": { "type": ["string", "null"] },
        "applicantIds": { "type": "array", "items": { "type": "string" }, "description": "subset of the case's applicants on this file" },
        "keyDates": { "type": "object", "description": "fileLogin, codeLoginDone, inProcess, sanction, disbursement, pddCleared, otcCleared, completed" },
        "remarks": { "type": ["string", "null"] },
        "createdAt": { "type": "object" }, "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" }, "updatedBy": { "type": "string" }
      },
      "required": ["caseId", "seq", "stage", "keyDates", "createdAt", "createdBy"]
    },
    "case_task": {
      "title": "Case Collaboration Task/Update (CRM 2.0 Phase 6)",
      "description": "/cases/{caseId}/tasks/{taskId}. The per-case collaboration thread. kind 'task' = actionable + assignable (status open/done); 'update' = an informational note (status done on create). Server-only writes. caseId + clientName are denormalised to power the cross-case Tasks page (GET /api/crm2/my-case-tasks).",
      "type": "object",
      "properties": {
        "caseId": { "type": "string", "description": "denormalised parent case id" },
        "clientName": { "type": ["string", "null"], "description": "denormalised case label" },
        "kind": { "type": "string", "enum": ["task", "update"] },
        "text": { "type": "string" },
        "assignedTo": { "type": ["string", "null"], "description": "FAPL-xxx (tasks only)" },
        "assignedToName": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["open", "done"] },
        "doneAt": { "type": ["object", "null"] },
        "doneBy": { "type": ["string", "null"], "description": "FAPL-xxx" },
        "createdByName": { "type": "string" },
        "createdAt": { "type": "object" }, "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" }, "updatedBy": { "type": "string" }
      },
      "required": ["caseId", "kind", "text", "status", "createdAt", "createdBy"]
    },
    "case_payout_mirror": {
      "title": "Case Payout Money Mirror (CRM 2.0)",
      "description": "/cases/{caseId}/private/payout. The money mirror — readable ONLY with the payout.amounts.read permission (doc-split so case readers without that perm never see economics). Server-only writes; populated at disbursement.",
      "type": "object",
      "properties": {
        "finvastraPayoutPct": { "type": ["number", "null"] },
        "finvastraPayoutExpected": { "type": ["number", "null"] },
        "subDsaPayoutPct": { "type": ["number", "null"] },
        "subDsaPayoutExpected": { "type": ["number", "null"] },
        "netMarginExpected": { "type": ["number", "null"] },
        "updatedAt": { "type": "object" }
      },
      "required": ["updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Metadata about users"
    },
    "/attendance/{attendanceId}": {
      "schema": "attendance",
      "description": "Phase 3 HRMS attendance logs with Firestore Timestamp check-in/out"
    },
    "/leave_applications/{applicationId}": {
      "schema": "leave_application",
      "description": "Phase 3 HRMS leave applications (replaces Phase 1 /leaves)"
    },
    "/leave_balances/{docId}": {
      "schema": "leave_balance",
      "description": "Annual leave balance per employee; doc ID equals employeeId"
    },
    "/holidays/{holidayId}": {
      "schema": "holiday",
      "description": "Company holiday calendar; readable by all authenticated users"
    },
    "/payslips/{payslipId}": {
      "schema": "payslip",
      "description": "Monthly payslips generated by admin from CA salary data"
    },
    "/commission_statements/{statementId}": { "schema": "commission_statement" },
    "/commission_statements/{statementId}/lines/{lineId}": { "schema": "statement_line" },
    "/rm_payout_slabs/{slabId}": { "schema": "rm_payout_slab" },
    "/rm_payouts/{payoutId}": { "schema": "rm_payout" },
    "/cases/{caseId}": { "schema": "case", "description": "CRM 2.0 case (FIN-CASE-YYYY-####). Read = isAdmin() || crm.cases.read; write = server-only (rule false; mutations via /api/crm2/*)." },
    "/cases/{caseId}/private/payout": { "schema": "case_payout_mirror", "description": "Money mirror — read = isAdmin() || payout.amounts.read; write = server-only." },
    "/cases/{caseId}/applicants/{applicantId}": { "schema": "case_applicant", "description": "Read = crm.cases.read; write = server-only." },
    "/cases/{caseId}/docTracker/{rowId}": { "schema": "case_doc_tracker", "description": "Read = crm.cases.read; write = server-only." },
    "/cases/{caseId}/stageHistory/{entryId}": { "schema": "case_stage_history", "description": "Append-only stage audit. Read = crm.cases.read; write = server-only." },
    "/cases/{caseId}/logins/{loginId}": { "schema": "case_login", "description": "Per-login pipeline (LGN-YYYY-####). Read = crm.cases.read; write = server-only." },
    "/cases/{caseId}/tasks/{taskId}": { "schema": "case_task", "description": "Phase 6 collaboration thread. Read = crm.cases.read; write = server-only." }
  }
}
