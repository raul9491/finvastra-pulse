rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net — deny everything not explicitly permitted
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Helpers ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    // ─── Role checks — CUSTOM CLAIM FIRST, Firestore get() as fallback ───────────
    // Each role helper checks request.auth.token.* first (stamped by
    // POST /api/admin/users/:uid/sync-claims). When the claim is present the get()
    // is short-circuited away — eliminating a /users document read on EVERY gated
    // request, which was the dominant driver of the free-tier 50k-reads/day cap.
    // The `|| get(...)` fallback means a user whose token lacks the claim (not yet
    // re-synced / token not refreshed) is still authorised via Firestore — so this
    // change can never lock anyone out. Tradeoff: a claim change (e.g. access
    // revoked) propagates on the next token refresh (≤1h) — acceptable and standard.
    function isAdmin() {
      return isSignedIn() && (
             request.auth.token.get('role', '') == 'admin' ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'employee') == 'admin'));
    }
    // ─── CRM 2.0 / Pipeline permission keys (PLAN.md decision 2) ────────────────
    // users/{uid}.perms map, mirrored into custom claims by sync-claims.
    // Claims-first; the get() fallback covers tokens that predate the perms sync.
    // Repeated get()s of the same doc within one evaluation are cached by Firestore.
    function hasCrm2Perm(key) {
      return isSignedIn() && (
             request.auth.token.get('perms', {}).get(key, false) == true ||
             isAdmin() ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('perms', {}).get(key, false) == true));
    }
    // Any Pipeline read permission — used by master collections (pickers need names).
    function hasAnyCrm2Read() {
      return hasCrm2Perm('crm.leads.read') || hasCrm2Perm('crm.cases.read')
          || hasCrm2Perm('crm.masters.write') || hasCrm2Perm('payout.read')
          || hasCrm2Perm('mis.read') || hasCrm2Perm('recon.read');
    }
    // Phase P: each module helper also accepts users holding ≥1 active page
    // share in that module ('crm'/'hrms'/'mis' in /users.sharedModules). A page
    // share therefore grants module-level DATA read; the UI restricts their
    // navigation to the shared pages. Accepted trade-off for a 25-person tool.
    // The sharedModules check lives in the get() FALLBACK branch — share-only
    // users carry no module claim, so the fallback runs for them; claim-holders
    // short-circuit before the read (no extra reads added).
    function hasCrmAccess() {
      return isSignedIn() && (
             request.auth.token.get('crmAccess', false) == true ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('crmAccess', false) == true ||
               'crm' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('sharedModules', []))));
    }
    // Any employee with HRMS self-service access (hrmsAccess absent = true by default).
    // Used to allow HRMS-only employees to submit employee_referral leads.
    function hasHrmsAccess() {
      return isSignedIn() && (
             request.auth.token.get('hrmsAccess', false) == true ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('hrmsAccess', true) == true ||
               'hrms' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('sharedModules', []))));
    }
    // Social Media module access (WhatsApp inbox). Not in custom claims — reads the
    // user doc (admins bypass earlier via isAdmin()). Grants reading leads + their
    // WhatsApp threads so the inbox can list conversations.
    function hasSocialAccess() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('socialAccess', false) == true;
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ─── Super admin protection ──────────────────────────────────────────────────
    // These UIDs match SUPER_ADMIN_UIDS in src/config/hrmsConfig.ts.
    // Hardcoded because rules cannot read env vars.
    // isSuperAdminUid()    → is the CALLER a super admin?
    // isSuperAdminTarget() → is the TARGET userId a super admin?
    function isSuperAdminUid() {
      return request.auth.uid in [
        '3zdX5QBnTbQAcTdLzUjfXxefP8r2',  // Ajay Newatia (FAPL-000)
        'ZmZaciATPDYBb1O2blYWBjjbzMv1',  // Kumar Mangalam (FAPL-003)
        '5lAbJ4CZ5uM0LbU4gUYItNRAlEn2'   // Rahul Vijay Wargia (FAPL-022)
      ];
    }
    function isSuperAdminTarget(userId) {
      return userId in [
        '3zdX5QBnTbQAcTdLzUjfXxefP8r2',
        'ZmZaciATPDYBb1O2blYWBjjbzMv1',
        '5lAbJ4CZ5uM0LbU4gUYItNRAlEn2'
      ];
    }

    // ─── Validation helpers ──────────────────────────────────────────────────────
    // isValidAttendance / isValidLeave removed — Phase 1 helpers superseded by Phase 3
    // HRMS rules at the bottom of this file (use Timestamp-based validation there).

    function isValidLead(data) {
      // Lead = person record. Deal data lives in the opportunities subcollection.
      return data.keys().hasAll([
               'displayName', 'phone', 'source', 'primaryOwnerId',
               'consentGiven', 'consentTimestamp', 'consentMethod',
               'createdBy', 'createdAt', 'tags', 'deleted'
             ]) &&
             data.keys().hasOnly([
               'displayName', 'phone', 'email', 'panRaw', 'panEncrypted', 'panMasked',
               'source', 'tags', 'primaryOwnerId', 'consentGiven', 'consentTimestamp',
               'consentMethod', 'createdBy', 'createdAt', 'updatedAt', 'deleted',
               'deletedAt', 'slaDeadline', 'triagePriority', 'importBatchId',
               'importHash', 'importedBy', 'importedAt', 'referredBy',
               'referrerName',
               // Phase Q connector (was missing — blocked connector-sourced customers)
               'connectorId', 'connectorCode', 'connectorName',
               // Field ops — GPS point captured when the RM adds a customer on-site
               'meetingLocation',
               // Team view "time with owner" anchor + Stage-2 SLA first-contact stamp
               'assignedToCurrentOwnerAt', 'firstContactedAt'
             ]) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 200 &&
             data.phone is string && data.phone.size() == 10 &&
             data.source in ['website', 'instagram', 'facebook', 'walkin', 'referral', 'sub_dsa', 'broker', 'offline_bulk', 'social_meta', 'employee_referral'] &&
             data.createdBy == request.auth.uid &&
             data.consentGiven == true &&
             data.consentMethod in ['verbal', 'written', 'digital', 'offline_collection'] &&
             data.deleted == false;
    }

    // Stricter variant for HRMS-employee referral submissions.
    // Deliberately limited field set — no PAN, no import fields, no triage.
    // The submitter's uid must be both referredBy and primaryOwnerId at creation time.
    function isValidReferralLead(data) {
      return data.keys().hasAll([
               'displayName', 'phone', 'source', 'primaryOwnerId', 'referredBy',
               'consentGiven', 'consentTimestamp', 'consentMethod',
               'createdBy', 'createdAt', 'tags', 'deleted'
             ]) &&
             data.keys().hasOnly([
               'displayName', 'phone', 'email',
               'source', 'tags', 'primaryOwnerId', 'referredBy',
               'consentGiven', 'consentTimestamp', 'consentMethod',
               'createdBy', 'createdAt', 'updatedAt', 'deleted'
             ]) &&
             data.displayName is string && data.displayName.size() >= 2 && data.displayName.size() <= 200 &&
             data.phone is string && data.phone.size() == 10 &&
             data.source == 'employee_referral' &&
             data.referredBy == request.auth.uid &&
             data.primaryOwnerId == request.auth.uid &&
             data.createdBy == request.auth.uid &&
             data.consentGiven == true &&
             data.consentMethod in ['verbal', 'written', 'digital', 'offline_collection'] &&
             data.deleted == false;
    }

    // Bank submission status must follow the defined progression.
    // Skipping steps (e.g. preparing → disbursed) is not allowed.
    // 'rejected' is terminal from any non-disbursed state.
    function validBankSubStatusTransition(from, to) {
      return from == to ||
             (from == 'preparing'  && to in ['submitted', 'rejected']) ||
             (from == 'submitted'  && to in ['in_review', 'rejected']) ||
             (from == 'in_review'  && to in ['sanctioned', 'rejected']) ||
             (from == 'sanctioned' && to in ['disbursed', 'rejected']);
    }

    // crmRole=lead_convertor requires convertorVertical; all other roles require it to be null.
    function validCrmRolePair(data) {
      return !data.keys().hasAny(['crmRole', 'convertorVertical', 'convertorVerticals']) ||
             (data.get('crmRole', null) == 'lead_convertor' &&
                ((data.get('convertorVerticals', null) is list && data.convertorVerticals.size() > 0)
                 || data.get('convertorVertical', null) != null)) ||
             (data.get('crmRole', null) != 'lead_convertor' &&
                data.get('convertorVertical', null) == null &&
                data.get('convertorVerticals', null) == null);
    }

    function isValidCommissionSlab(data) {
      // Exactly one of percentage or flatFee must be present — not both, not neither
      return data.keys().hasAll(['providerId', 'product', 'minTicket', 'basisOn',
                                  'effectiveFrom', 'active', 'lastModifiedBy']) &&
             data.minTicket is number && data.minTicket >= 0 &&
             data.basisOn in ['sanctioned', 'disbursed'] &&
             (
               ('percentage' in data && !('flatFee' in data)) ||
               (!('percentage' in data) && 'flatFee' in data)
             );
    }

    function isValidActivity(data) {
      // Phase P: byName + opportunityId added for QuickLogBar (optional keys —
      // existing writers that omit them remain valid).
      // Phase R: location {lat,lng} — GPS-tagged customer visits by field RMs.
      return data.keys().hasAll(['type', 'content', 'by', 'at']) &&
             data.keys().hasOnly(['type', 'content', 'by', 'at', 'relatedDocId', 'byName', 'opportunityId', 'location']) &&
             data.type in ['call', 'email', 'whatsapp', 'meeting', 'note', 'status_change', 'ownership_change', 'commission_calculated'] &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
             data.by == request.auth.uid;
    }

    // Phase P: author may edit an activity's content for 5 minutes after logging.
    function canEditOwnActivityContent() {
      return isSignedIn() &&
             request.auth.uid == resource.data.by &&
             request.time < resource.data.at + duration.value(5, 'm') &&
             incoming().diff(existing()).affectedKeys().hasOnly(['content']) &&
             incoming().content is string && incoming().content.size() > 0 && incoming().content.size() <= 2000;
    }

    // ─── Users (org directory — readable by all signed-in employees) ────────────
    // No personal data here. Personal fields live in /user_details/{userId}.
    match /users/{userId} {
      allow get:  if isSignedIn();
      allow list: if isSignedIn();

      // First sign-in bootstrap.
      // Regular employees land as 'employee'. Admin email is verified by Firebase Auth
      // (request.auth.token.email cannot be spoofed) so we allow it to self-create as 'admin'.
      allow create: if isOwner(userId) &&
                       incoming().keys().hasOnly([
                         'userId', 'email', 'displayName', 'role', 'photoURL', 'createdAt',
                         'employeeId', 'department', 'designation', 'managerId',
                         'joiningDate', 'location', 'leaveBalance',
                         'hrmsAccess', 'crmAccess', 'hasCalendarAccess'
                       ]) &&
                       incoming().keys().hasAll(['userId', 'email', 'displayName', 'role', 'photoURL']) &&
                       incoming().userId == request.auth.uid &&
                       incoming().email == request.auth.token.email &&
                       (
                         incoming().role == 'employee' ||
                         (incoming().role == 'admin' && request.auth.token.email == 'rahulv@finvastra.com')
                       );

      allow update: if isSignedIn() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly([
          'displayName', 'photoURL', 'location',
          'leaveBalance', 'hasCalendarAccess',
          'mustResetPassword',  // employee clears this after setting their own password
          'onboarding',         // first-run tour-seen flags (self-marked per module)
          'uiPrefs'             // Phase 6: pinned pages + open sidebar sections (cross-device)
        ])) ||
        // Admin can update any user field, but:
        // (a) crmRole/convertorVertical must be a valid pair
        // (b) super admin accounts can only be updated by another super admin
        // (c) Phase P: only a (hardcoded) super admin may touch the superAdmin
        //     promotion flag — prevents a plain admin self-promoting via API
        (isAdmin() && validCrmRolePair(incoming()) &&
         (!isSuperAdminTarget(userId) || isSuperAdminUid()) &&
         (!incoming().diff(existing()).affectedKeys().hasAny(['superAdmin']) || isSuperAdminUid()))
      );
    }

    // ─── User details (personal data — private) ──────────────────────────────────
    // Contains phone, personal email, DOB, address, family info, last working date.
    // Admin + HRMS manager can read all and write all fields.
    // Employees can read their own and update only 7 self-service fields:
    //   phone, personalEmail, presentAddress, bloodGroup, emergencyContact* (3 fields), updatedAt.
    match /user_details/{userId} {
      allow get:    if isAdmin() || isHrmsManager() || isOwner(userId);
      allow list:   if isAdmin() || isHrmsManager();
      allow create: if isAdmin() || isHrmsManager();
      allow update: if isAdmin() || isHrmsManager() ||
                       (isOwner(userId) &&
                        incoming().diff(existing()).affectedKeys().hasOnly([
                          'phone', 'personalEmail', 'presentAddress', 'bloodGroup',
                          'emergencyContactName', 'emergencyContactPhone',
                          'emergencyContactRelationship', 'updatedAt'
                        ]));
      allow delete: if false;
    }

    // ─── Employee profiles (HR data: PAN/bank/aadhaar compliance) ───────────────
    // Admin + HRMS manager only. Sensitive data; employees do not read own profile here.
    match /employee_profiles/{empCode} {
      allow read:          if isAdmin() || isHrmsManager();
      allow create, update: if isAdmin() || isHrmsManager();
      allow delete:         if false;
    }

    // ─── Employee sensitive data (bank + salary) ─────────────────────────────────
    // Admin: full read/write. HRMS Manager: read all (needed for payslips).
    // Employee: read own only. Salary changes are admin-only (financial decisions).
    match /employee_sensitive/{userId} {
      allow get:    if isAdmin() || isHrmsManager() || isOwner(userId);
      allow list:   if isAdmin() || isHrmsManager();
      allow create,
            update: if isAdmin();
      allow delete: if false;
    }

    // ─── Attendance / Leaves / Payroll ───────────────────────────────────────────
    // Phase 1 placeholder rules removed. Phase 3 HRMS rules are at the bottom of
    // this file: /attendance/{recordId}, /leave_applications/{applicationId},
    // /leave_balances/{docId}, /holidays/{holidayId}, /payslips/{payslipId}.
    // The old /leaves and /payroll collections are superseded by the Phase 3 schema.

    // ─── Notifications (flat — legacy) ───────────────────────────────────────────
    match /notifications/{notifId} {
      allow get:    if isOwner(existing().get('userId', '')) || isAdmin();
      allow list:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(existing().get('userId', '')) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin() || isOwner(existing().get('userId', ''));
    }

    // ─── Notifications (per-user subcollection — employee referral alerts) ────────
    // Any signed-in user may push a new_referral notification to a generator's inbox.
    // Only the target user may read or mark read their own items.
    match /notifications/{uid}/items/{itemId} {
      allow create: if isSignedIn() &&
                       incoming().keys().hasOnly([
                         'type', 'leadId', 'leadName', 'submittedBy', 'createdAt', 'read'
                       ]) &&
                       incoming().type == 'new_referral';
      allow get,
            list:   if request.auth.uid == uid;
      allow update: if request.auth.uid == uid &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }

    // ─── CRM: Leads (person record) ──────────────────────────────────────────────
    match /leads/{leadId} {
      // Admin sees all; RM sees their primary leads; HRMS employee tracks their own referrals.
      allow get:  if isAdmin() ||
                     (hasCrmAccess() && resource.data.primaryOwnerId == request.auth.uid) ||
                     isManagerOf(resource.data.primaryOwnerId) ||
                     resource.data.get('referredBy', null) == request.auth.uid ||
                     hasCrm2Perm('crm.leads.read') ||   // CRM 2.0 Pipeline readers
                     hasSocialAccess();                 // Social Media inbox (WhatsApp)
      allow list: if isAdmin() ||
                     (hasCrmAccess() && resource.data.primaryOwnerId == request.auth.uid) ||
                     // Manager team view — works for queries that pin primaryOwnerId
                     // to a single value (the client queries per direct report).
                     isManagerOf(resource.data.primaryOwnerId) ||
                     // Distributors (managers / crmCanImport) may list/count the
                     // UNASSIGNED pool — the Import Queue's live remaining-count
                     // needs it (query must pin primaryOwnerId == 'UNASSIGNED').
                     // Telecallers stay blocked (pool is count-only for them).
                     ((isManager() || hasCrmImport()) && resource.data.primaryOwnerId == 'UNASSIGNED') ||
                     resource.data.get('referredBy', null) == request.auth.uid ||
                     hasCrm2Perm('crm.leads.read') ||   // CRM 2.0 Pipeline readers
                     hasSocialAccess();                 // Social Media inbox (WhatsApp)

      // Admin always bypasses crmAccess — needed when the user doc was bootstrapped
      // with crmAccess:false on first emulator sign-in before admin role was set.
      // HRMS-only employees may submit employee_referral leads via isValidReferralLead().
      allow create: if ((hasCrmAccess() || isAdmin()) && isValidLead(incoming()))
                       || (hasHrmsAccess() && isValidReferralLead(incoming()));

      // Admin updates any field; primary owner can update non-consent, non-PAN fields.
      // slaDeadline is allowed only when CLEARED to null (e.g. on deal close) — owners
      // cannot extend their own SLA to dodge the overdue badge.
      // FIFO queue fields (assignedRm/assignedAt/status/releaseCount/lastReleaseReason/
      // queueFlagged on CRM 2.0 leads) are NOT in the owner allowlist below and CRM 2.0
      // leads carry no primaryOwnerId, so non-admins can't update them — mutated only by
      // /api/crm2/queue/* (Admin SDK). queueSkills lives on /users (admin-write only).
      allow update: if isAdmin() ||
                       (hasCrmAccess() &&
                        (resource.data.primaryOwnerId == request.auth.uid
                         || isManagerOf(resource.data.primaryOwnerId)) &&
                        incoming().diff(existing()).affectedKeys().hasOnly([
                          'displayName', 'phone', 'email', 'source', 'tags',
                          'primaryOwnerId', 'assignedToCurrentOwnerAt', 'updatedAt', 'slaDeadline',
                          'leadStatus', 'leadStatusAt', 'leadStatusBy',
                          'callbackAt', 'callbackReminderSent',
                          'meetingLocation',
                          // Stage-2 SLA: owner stamps first-contact (set-once, client-side).
                          // The slaStage1/2BreachedAt fields are deliberately ABSENT here —
                          // server-only (Admin SDK) so they can't be cleared to dodge alerts.
                          'firstContactedAt'
                        ]) &&
                        (!incoming().diff(existing()).affectedKeys().hasAny(['slaDeadline'])
                         || incoming().slaDeadline == null));

      allow delete: if false;  // soft delete only — set deleted:true via admin update
    }

    // ─── CRM: Meetings (scheduled customer meetings → scheduler's Google Calendar) ─
    // Writes go through Express (Admin SDK), which also does the calendar sync.
    // Company-wide: any CRM user may schedule + read meetings (non-sensitive — a
    // customer reference + a time), so the customer's meeting list shows to whoever
    // is working it. Admin always; managers via the team relationship too.
    match /crm_meetings/{meetingId} {
      allow read: if isAdmin() || hasCrmAccess() || isManagerOf(resource.data.ownerId);
      allow write: if false;  // server-only (Admin SDK) — keeps calendar + doc in lockstep
    }

    // ─── CRM: Opportunities (deal record) ────────────────────────────────────────
    match /leads/{leadId}/opportunities/{oppId} {
      // Admin + lead's primaryOwner + opportunity's ownerId can all read
      allow get, list: if isAdmin() ||
                          (hasCrmAccess() && (
                            resource.data.ownerId == request.auth.uid ||
                            get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId == request.auth.uid
                          )) ||
                          isManagerOf(get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId);

      // Only admin or lead's primary owner can create opportunities on that lead
      allow create: if isAdmin() ||
                       (hasCrmAccess() &&
                        get(/databases/$(database)/documents/leads/$(leadId)).data.get('primaryOwnerId','') == request.auth.uid);

      // Admin updates any field. The opportunity's owner, the LEAD's primary owner
      // (the generator — the handoff pattern keeps them on the relationship), or the
      // owner's reporting manager may update working fields. `ownerId` is in the
      // allowlist so TRANSFER-to-specialist works for non-admins (2026-07-02 fix —
      // it was rules-broken for the exact roles it was built for: a generator's
      // transferOpportunity batch was denied because ownerId wasn't updatable).
      // Blast radius is safe: you can only hand off a deal you own / sourced / manage.
      allow update: if isAdmin() ||
                       (hasCrmAccess() &&
                        (resource.data.ownerId == request.auth.uid ||
                         get(/databases/$(database)/documents/leads/$(leadId)).data.get('primaryOwnerId','') == request.auth.uid ||
                         isManagerOf(resource.data.ownerId)) &&
                        incoming().diff(existing()).affectedKeys().hasOnly([
                          'stage', 'status', 'notes', 'expectedCloseDate',
                          'actualCloseDate', 'updatedAt', 'customFields', 'stageData',
                          'lostDetails', 'ownerId'
                        ]));

      allow delete: if false;
    }

    // ─── CRM: Opportunity Activities ─────────────────────────────────────────────
    match /leads/{leadId}/opportunities/{oppId}/activities/{actId} {
      allow read: if isAdmin() ||
                     (hasCrmAccess() && (
                       get(/databases/$(database)/documents/leads/$(leadId)/opportunities/$(oppId)).data.ownerId == request.auth.uid ||
                       get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId == request.auth.uid
                     )) ||
                     isManagerOf(get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId);
      allow create: if hasCrmAccess() && isValidActivity(incoming());
      // Phase P: author can edit their own activity's content within 5 minutes.
      allow update: if isAdmin() || canEditOwnActivityContent();
      allow delete: if isAdmin();
    }

    // ─── CRM: Lead-level Activities (Phase P — QuickLogBar) ──────────────────────
    // A lead-level feed independent of any opportunity (raw leads have none).
    // Read mirrors lead access; create validated like opportunity activities.
    match /leads/{leadId}/activities/{actId} {
      allow read: if isAdmin() ||
                     (hasCrmAccess() &&
                      get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId == request.auth.uid) ||
                     isManagerOf(get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId);
      allow create: if hasCrmAccess() && isValidActivity(incoming());
      allow update: if isAdmin() || canEditOwnActivityContent();
      allow delete: if isAdmin();
    }

    // ─── Social Media: WhatsApp conversation thread (per lead) ───────────────────
    // One doc per message at /leads/{id}/whatsapp/{waMessageId}. Read = lead access
    // OR social-inbox access; writes are SERVER-ONLY (inbound webhook + send endpoint
    // via the Admin SDK), so a client can never forge a message.
    match /leads/{leadId}/whatsapp/{msgId} {
      allow read:  if isAdmin() || hasSocialAccess() || hasCrmAccess() || hasCrm2Perm('crm.leads.read');
      allow write: if false;
    }

    // ─── CRM: Bank Submissions ───────────────────────────────────────────────────
    match /leads/{leadId}/opportunities/{oppId}/bank_submissions/{subId} {
      // Opportunity owner + lead primary owner + admin can read
      allow get, list: if isAdmin() ||
                          (hasCrmAccess() && (
                            get(/databases/$(database)/documents/leads/$(leadId)/opportunities/$(oppId)).data.ownerId == request.auth.uid ||
                            get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId == request.auth.uid
                          ));

      // Only the opportunity owner or admin can create a bank submission
      allow create: if (isAdmin() ||
                        (hasCrmAccess() &&
                         get(/databases/$(database)/documents/leads/$(leadId)/opportunities/$(oppId)).data.ownerId == request.auth.uid)) &&
                       incoming().keys().hasAll(['providerId', 'status', 'isPrimary', 'createdAt', 'createdBy', 'updatedAt', 'statusHistory']) &&
                       incoming().keys().hasOnly([
                         'providerId', 'status', 'isPrimary', 'createdAt', 'createdBy',
                         'updatedAt', 'notes', 'requestedAmount', 'statusHistory',
                         'documentStatus', 'documentStatusLog'
                       ]) &&
                       incoming().status == 'preparing' &&
                       incoming().isPrimary == false;

      // Status transitions must follow the defined progression.
      // isPrimary can only become true when status is 'disbursed'.
      allow update: if (isAdmin() ||
                        (hasCrmAccess() &&
                         get(/databases/$(database)/documents/leads/$(leadId)/opportunities/$(oppId)).data.ownerId == request.auth.uid)) &&
                       incoming().diff(existing()).affectedKeys().hasOnly([
                         'status', 'updatedAt', 'submittedAt', 'decisionAt', 'disbursedAt',
                         'sanctionedAmount', 'disbursedAmount', 'requestedAmount',
                         'interestRate', 'tenureMonths', 'isPrimary',
                         'rejectionReason', 'notes', 'statusHistory',
                         'documentStatus', 'documentStatusLog'
                       ]) &&
                       // Status can only change along the valid progression path
                       (!incoming().diff(existing()).affectedKeys().hasAny(['status']) ||
                        validBankSubStatusTransition(existing().status, incoming().status)) &&
                       // isPrimary=true is only permitted when status is 'disbursed'
                       (!incoming().diff(existing()).affectedKeys().hasAny(['isPrimary']) ||
                        !incoming().isPrimary ||
                        incoming().status == 'disbursed');

      // Only admin can delete submission records
      allow delete: if isAdmin();
    }

    // ─── CRM: Wealth Investments ─────────────────────────────────────────────────
    match /leads/{leadId}/opportunities/{oppId}/investments/{investId} {
      allow read: if isAdmin() ||
                     (hasCrmAccess() && (
                       get(/databases/$(database)/documents/leads/$(leadId)/opportunities/$(oppId)).data.ownerId == request.auth.uid ||
                       get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId == request.auth.uid
                     ));
      allow create: if isAdmin() ||
                       (hasCrmAccess() && (
                         get(/databases/$(database)/documents/leads/$(leadId)/opportunities/$(oppId)).data.ownerId == request.auth.uid ||
                         get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId == request.auth.uid
                       ));
      allow update: if isAdmin() ||
                       (hasCrmAccess() &&
                        get(/databases/$(database)/documents/leads/$(leadId)/opportunities/$(oppId)).data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── CRM: Insurance Policies ─────────────────────────────────────────────────
    match /leads/{leadId}/opportunities/{oppId}/policies/{policyId} {
      allow read: if isAdmin() ||
                     (hasCrmAccess() && (
                       get(/databases/$(database)/documents/leads/$(leadId)/opportunities/$(oppId)).data.ownerId == request.auth.uid ||
                       get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId == request.auth.uid
                     ));
      allow create: if isAdmin() ||
                       (hasCrmAccess() && (
                         get(/databases/$(database)/documents/leads/$(leadId)/opportunities/$(oppId)).data.ownerId == request.auth.uid ||
                         get(/databases/$(database)/documents/leads/$(leadId)).data.primaryOwnerId == request.auth.uid
                       ));
      allow update: if isAdmin() ||
                       (hasCrmAccess() &&
                        get(/databases/$(database)/documents/leads/$(leadId)/opportunities/$(oppId)).data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── CRM: Config — Opportunity Types ─────────────────────────────────────────
    match /opportunity_types/{typeId} {
      allow read:  if hasCrmAccess() || isAdmin();
      allow write: if isAdmin();
    }

    // ─── CRM: Config — Providers ─────────────────────────────────────────────────
    match /providers/{providerId} {
      allow read:  if hasCrmAccess() || isAdmin();
      allow write: if isAdmin();
    }

    // ─── CRM: Config — Document Types ───────────────────────────────────────────
    match /document_types/{typeId} {
      allow read:  if hasCrmAccess() || isAdmin();
      allow write: if isAdmin();
    }

    // ─── CRM: Commission Slabs ───────────────────────────────────────────────────
    match /commission_slabs/{slabId} {
      allow read:   if hasCrmAccess() || isAdmin();
      allow create,
            update: if isAdmin() && isValidCommissionSlab(incoming());
      allow delete: if isAdmin();  // deactivation preferred over deletion
    }

    // ─── CRM: Commission Records ─────────────────────────────────────────────────
    match /commission_records/{recordId} {
      // Admin sees all; RM sees only their own records
      allow read: if isAdmin() ||
                     (hasCrmAccess() && resource.data.rmOwnerId == request.auth.uid);
      // Records are created by the RM's own client session on primary disbursal.
      // Phase 6: move to Cloud Function so the client cannot set slabId or amounts.
      allow create: if hasCrmAccess() &&
                       incoming().rmOwnerId == request.auth.uid &&
                       incoming().status == 'pending' &&
                       incoming().calculatedCommission >= 0;
      // Admin updates: status, payment, clawback fields
      // RM updates: disbursal reference fields only (Loan No, App No, etc.) on own record
      allow update: if (isAdmin() &&
                        incoming().diff(existing()).affectedKeys().hasOnly([
                          'status', 'actualPayoutDate', 'actualAmount',
                          'clawbackReason', 'notes', 'paidAt', 'updatedAt'
                        ])) ||
                       (hasCrmAccess() &&
                        resource.data.rmOwnerId == request.auth.uid &&
                        incoming().diff(existing()).affectedKeys().hasOnly([
                          'loanNo', 'applicationNo', 'disbursedAmount',
                          'disbursalDate', 'dsaCode', 'dsaName', 'cityState',
                          'customerCompanyName', 'updatedAt'
                        ]));
      // Never delete — audit trail integrity (aligns with MIS matchedRecordId references)
      allow delete: if false;
    }

    // ─── Commission Leakage Reports ──────────────────────────────────────────────
    match /commission_leakage_reports/{reportId} {
      allow read:   if isAdmin();
      allow write:  if false;  // server-only (Admin SDK bypasses rules)
    }

    // ─── Import Logs (bulk data imports from Data Import page) ──────────────────
    // Written by admin client after each successful import. Read by admin only.
    match /import_logs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAdmin() &&
                       request.resource.data.keys().hasAll(['importType','filename','rowCount','importedBy','importedAt']) &&
                       request.resource.data.importedBy == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Import Jobs ─────────────────────────────────────────────────────────────
    match /import_jobs/{jobId} {
      // Triggering user can read their own job's progress; admin sees all.
      // Managers + crmCanImport users can also read — the server lets them
      // DISTRIBUTE batches, so the Import Queue must show them jobs an admin
      // imported (it was showing "Nothing awaiting" — 2026-07-02 fix).
      allow read: if isAdmin() || isManager() || hasCrmImport() ||
                     (isSignedIn() && resource.data.triggeredBy == request.auth.uid);
      // Written exclusively by the server (Firebase Admin SDK bypasses these rules)
      allow create: if false;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Access Requests ─────────────────────────────────────────────────────────
    // Public submit (unauthenticated users can request access).
    // Only admin can read/update/review requests.
    match /access_requests/{requestId} {
      allow create: if true;
      allow read:   if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── Claims & Reimbursements ─────────────────────────────────────────────────
    match /claims/{claimId} {
      allow create: if isSignedIn() &&
                       incoming().employeeId == request.auth.uid &&
                       incoming().status == 'pending' &&
                       incoming().keys().hasAll(['employeeId', 'employeeName', 'claimType', 'amount', 'description', 'status', 'submittedAt', 'month']) &&
                       incoming().amount is number && incoming().amount > 0 && incoming().amount <= 50000;
      allow read:   if isAdmin() || isHrmsManager() ||
                       (isSignedIn() && resource.data.get('employeeId', '') == request.auth.uid);
      allow update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── Company Documents ────────────────────────────────────────────────────────
    match /company_documents/{docId} {
      allow read:   if isSignedIn();
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── Employee Documents ───────────────────────────────────────────────────────
    match /employee_documents/{docId} {
      allow read:   if isAdmin() || isHrmsManager() ||
                       (isSignedIn() && resource.data.get('employeeId', '') == request.auth.uid);
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── IT Declarations ─────────────────────────────────────────────────────────
    // Doc ID: {employeeId}_{year}
    match /it_declarations/{docId} {
      allow read:   if isAdmin()
                    || isHrmsManager()
                    || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.employeeId == request.auth.uid
                    && request.resource.data.status == 'draft';
      allow update: if (isSignedIn()
                        && resource.data.employeeId == request.auth.uid
                        && resource.data.status != 'accepted')
                    || isAdmin()
                    || isHrmsManager();
      allow delete: if false;
    }

    // ─── Announcements ────────────────────────────────────────────────────────────
    match /announcements/{announcementId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin() || isHrmsManager();
      allow update: if isAdmin() || isHrmsManager() ||
                       // Any signed-in employee may append their own uid to readBy.
                       // Constraints ensure: only readBy changes, no entries removed,
                       // exactly one uid added, and that uid is the requesting user's own.
                       (isSignedIn() &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['readBy']) &&
                        incoming().readBy.hasAll(existing().readBy) &&
                        incoming().readBy.size() == existing().readBy.size() + 1 &&
                        incoming().readBy.hasAll([request.auth.uid]));
      allow delete: if false;
    }

    // ─── Webhook Logs ────────────────────────────────────────────────────────────
    // Written exclusively by the server (Admin SDK bypasses rules).
    // Admin read-only for the WebhookConfigPage — client-side reads go via
    // GET /api/admin/webhook-logs proxy endpoint which handles auth.
    match /webhook_logs/{logId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Meta Lead Ads webhook write-ahead store (one doc per leadgen_id; state machine
    // pending→fetching→done / failed). Server-only via Admin SDK; admin read for debug.
    match /meta_lead_events/{leadgenId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Meta leadgen dead-letters — events that exhausted retries or are unusable.
    // Server-only write (Admin SDK); admin read for an ops view / alerting.
    match /meta_lead_deadletters/{leadgenId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // WhatsApp inbound message write-ahead store (one doc per waMessageId; state
    // machine pending→processing→done / failed) + dead-letters. Server-only via the
    // Admin SDK; admin read for debug/ops. (Social Media module.)
    match /whatsapp_message_events/{messageId} {
      allow read:  if isAdmin();
      allow write: if false;
    }
    match /whatsapp_message_deadletters/{messageId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ─── Rate Limits (Firestore-based rate limiting) ─────────────────────────────
    // Server-only: Admin SDK bypasses rules. Client access denied.
    match /rate_limits/{key} {
      allow read, write: if false;
    }

    // ─── Audit Logs ──────────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read:   if isAdmin();
      allow create: if isSignedIn(); // server-side writes; client writes allowed for now
      allow update: if false;        // audit logs are immutable
      allow delete: if false;
    }

    // ─── Access Logs ─────────────────────────────────────────────────────────────
    match /access_logs/{logId} {
      allow read:   if isAdmin();
      allow create: if false;  // server-only (Admin SDK bypasses rules)
      allow update: if false;
      allow delete: if false;
    }

    // ─── Lead View Audit Log ─────────────────────────────────────────────────────
    // Written client-side when any authenticated user opens a lead detail page.
    // Only the user themselves can write their own view record.
    // Admin-only read — used to detect employees systematically mining the customer list.
    match /lead_view_logs/{logId} {
      allow read:   if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.viewedBy == request.auth.uid
                    && request.resource.data.keys().hasAll(['viewedBy','leadId','viewedAt']);
      allow update: if false;
      allow delete: if false;
    }

    // ─── RTBF Log ────────────────────────────────────────────────────────────────
    // Records the fact of an erasure request (not the original PII).
    // Written by CRM admins; immutable once created.
    match /rtbf_log/{eventId} {
      allow read:   if isAdmin();
      allow create: if hasCrmAccess() &&
                       incoming().keys().hasAll(['leadId', 'initiatedBy', 'initiatedAt', 'reason']) &&
                       incoming().initiatedBy == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Public Tracker Links ─────────────────────────────────────────────────────
    match /public_tracker_links/{token} {
      allow read:  if false;   // served exclusively via /api/track/:token server endpoint
      allow write: if false;   // server-only writes (Admin SDK)
    }

    // ─── User Subcollections ─────────────────────────────────────────────────────

    // Login history — append-only by the owner; readable by owner + admin.
    // Phase 6: server-side trim to last 50 entries.
    match /users/{userId}/login_history/{eventId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Known devices — owner can register and update lastSeen; owner or admin can remove.
    match /users/{userId}/known_devices/{fingerprintHash} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // Only lastSeenAt may be mutated after creation — prevents retroactive fingerprint spoofing.
      allow update: if isOwner(userId) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['lastSeenAt']);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ─── HRMS: Helpers ───────────────────────────────────────────────────────────
    // Claim-first (see role-check note near the top) — get() only as fallback.
    function isHrmsManager() {
      return isSignedIn() && (
             request.auth.token.get('isHrmsManager', false) == true ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isHrmsManager', false) == true));
    }
    // CRM manager (crmRole === 'manager') — used by Targets + reports.
    function isManager() {
      return isSignedIn() && (
             request.auth.token.get('crmRole', '') == 'manager' ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('crmRole', null) == 'manager'));
    }
    // Bulk-import distributor flag (crmCanImport on the user doc — no custom claim,
    // so this is a get() check). Matches the server's /api/import/* guards.
    function hasCrmImport() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('crmCanImport', false) == true;
    }
    // True when the caller is a CRM manager AND the given user reports to them
    // (HRMS reporting line). Lets a director view/edit their team's leads.
    function isManagerOf(ownerUid) {
      return isManager() &&
             exists(/databases/$(database)/documents/users/$(ownerUid)) &&
             get(/databases/$(database)/documents/users/$(ownerUid)).data.get('reportingManagerUid', '') == request.auth.uid;
    }

    // ─── HRMS: Attendance ─────────────────────────────────────────────────────────
    match /attendance/{recordId} {
      allow read:   if isAdmin() || isHrmsManager() ||
                       (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
      allow create: if isSignedIn() &&
                       incoming().keys().hasAll(['userId', 'date', 'status']) &&
                       incoming().userId == request.auth.uid &&
                       incoming().date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
      allow update: if isAdmin() || isHrmsManager() ||
                       // Employee can only check out their own record
                       (isSignedIn() &&
                        resource.data.get('userId', '') == request.auth.uid &&
                        incoming().diff(existing()).affectedKeys().hasOnly(
                          ['checkOut', 'checkOutLocation', 'workingHours', 'status', 'updatedAt']
                        ));
      allow delete: if false;
    }

    // ─── App config (admin-set platform settings, e.g. attendance geofence) ─────
    // Readable by everyone signed in (the attendance page must check the fence);
    // writable by admin / HR manager only. No PII lives here.
    match /app_config/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin() || isHrmsManager();
    }

    // ─── HRMS: Leave Applications ────────────────────────────────────────────────
    match /leave_applications/{applicationId} {
      allow read:   if isAdmin() || isHrmsManager() ||
                       (isSignedIn() && resource.data.get('employeeId', '') == request.auth.uid);
      allow create: if isSignedIn() &&
                       incoming().keys().hasAll(['employeeId', 'type', 'fromDate', 'toDate', 'days', 'reason', 'status']) &&
                       incoming().employeeId == request.auth.uid &&
                       incoming().status == 'pending';
      allow update: if isAdmin() || isHrmsManager() ||
                       (isSignedIn() &&
                        resource.data.get('employeeId', '') == request.auth.uid &&
                        resource.data.status == 'pending' &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                        incoming().status == 'cancelled');
      allow delete: if false;
    }

    // ─── HRMS: Leave Balances ─────────────────────────────────────────────────────
    match /leave_balances/{docId} {
      allow read:   if isAdmin() || isHrmsManager() ||
                       (isSignedIn() && docId == request.auth.uid);
      allow write:  if isAdmin() || isHrmsManager();
    }

    // ─── HRMS: Leave Balance Adjustments (audit trail) ───────────────────────────
    // Immutable audit log — create-only. No updates or deletes ever permitted.
    match /leave_balance_adjustments/{id} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create: if isAdmin() || isHrmsManager();
      allow update: if false;
      allow delete: if false;
    }

    // ─── HRMS: Holidays ───────────────────────────────────────────────────────────
    match /holidays/{holidayId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }

    // ─── HRMS: Payslips ───────────────────────────────────────────────────────────
    match /payslips/{payslipId} {
      allow read:   if isAdmin() || isHrmsManager() ||
                       (isSignedIn() && resource.data.get('employeeId', '') == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── MIS: Helpers ─────────────────────────────────────────────────────────────
    // Claim-first (see role-check note near the top) — get() only as fallback.
    // Phase P: also true for users with an active MIS page share (sharedModules).
    function hasMisAccess() {
      return isSignedIn() && (
             request.auth.token.get('misAccess', '') != '' ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('misAccess', null) != null ||
               'mis' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('sharedModules', []))));
    }
    function isMisAdmin() {
      return isSignedIn() && (
             request.auth.token.get('misAccess', '') == 'admin' ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('misAccess', '') == 'admin'));
    }

    // ─── MIS: Commission Statements ───────────────────────────────────────────────
    match /commission_statements/{statementId} {
      allow read:   if isAdmin() || hasMisAccess();
      allow create: if isAdmin() || isMisAdmin();
      allow update: if isAdmin() || isMisAdmin();
      allow delete: if false;

      match /lines/{lineId} {
        allow read:  if isAdmin() || hasMisAccess();
        allow write: if isAdmin() || isMisAdmin();
      }
    }

    // ─── MIS: RM Payout Slabs ─────────────────────────────────────────────────────
    match /rm_payout_slabs/{slabId} {
      // AUDIT FIX: was isSignedIn() — payout percentages are confidential.
      // Only MIS users and admin can read. Prevents regular employees from
      // seeing RM compensation structure.
      allow read:  if isAdmin() || hasMisAccess();
      allow write: if isAdmin() || isMisAdmin();
    }

    // ─── MIS: RM Payouts ──────────────────────────────────────────────────────────
    match /rm_payouts/{payoutId} {
      allow read:   if isAdmin() || hasMisAccess() ||
                       (isSignedIn() && resource.data.get('rmId', '') == request.auth.uid);
      allow create: if isAdmin() || isMisAdmin();
      allow update: if isAdmin() || isMisAdmin();
      allow delete: if false;
    }

    // ─── HRMS: Compliance Records ─────────────────────────────────────────────────
    // Admin and HRMS managers read and write. Delete is allowed so they can
    // re-sync a month with the CA calendar (the page deletes only UNFILED items
    // before re-seeding). These are operational reminders, not legal-retention
    // records, so immutability isn't required here.
    match /compliance_records/{recordId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if isAdmin() || isHrmsManager();
    }

    // ─── HRMS: Asset Management ───────────────────────────────────────────────────
    // Admin and HRMS managers only — employees do not see the asset inventory.
    match /assets/{assetId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── Connectors (channel partners / DSAs) ─────────────────────────────────────
    // Managed in HRMS by admin/HR. The main record is also readable by CRM users so
    // their name populates in the add-case picker. CRM users may also CREATE a
    // connector (quick-add when a partner walks in with a case) — main record only;
    // edits stay admin/HR. Sensitive PAN + bank live in a /private sub-doc readable
    // only by admin/HR. Soft-delete only (deleted flag).
    match /connectors/{connectorId} {
      allow read:   if isAdmin() || isHrmsManager() || hasCrmAccess();
      allow create: if isAdmin() || isHrmsManager() || hasCrmAccess();
      allow update: if isAdmin() || isHrmsManager();
      allow delete: if false;

      match /private/{docId} {
        allow read, write: if isAdmin() || isHrmsManager();
      }
    }

    // What Finvastra owes a connector for a sourced case. Admin/HR only.
    match /connector_payouts/{payoutId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── HRMS: Onboarding Checklists ──────────────────────────────────────────────
    // Admin and HRMS managers only — created on employee add / reactivation.
    match /onboarding_checklists/{docId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── HRMS: Offboarding Checklists ─────────────────────────────────────────────
    // Admin and HRMS managers only — created on employee deactivation.
    match /offboarding_checklists/{docId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── HRMS: Performance Reviews ──────────────────────────────────────────────
    // Employees can read and update (self-assessment only) their own review doc.
    // Admin and HrmsManager can read all and perform all writes.
    match /performance_reviews/{docId} {
      allow read: if isAdmin() || isHrmsManager()
                  || resource.data.employeeId == request.auth.uid;
      // Employee can only update selfAssessment + status + updatedAt on their own doc
      allow update: if isAdmin() || isHrmsManager()
                    || (resource.data.employeeId == request.auth.uid
                        && request.resource.data.keys().hasOnly(
                             ['selfAssessment', 'status', 'updatedAt']));
      allow create: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── HRMS: Probation Records ────────────────────────────────────────────────
    // Admin and HRMS managers only. Auto-created on employee join; updated as
    // HR reviews, confirms, or extends. No deletes — permanent audit trail.
    match /probation_records/{docId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── HRMS: Recruitment — Job Openings ───────────────────────────────────────
    // Admin and HRMS managers only. No physical deletes; close an opening by
    // setting status = 'closed'.
    match /job_openings/{docId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── HRMS: Recruitment — Candidates ─────────────────────────────────────────
    // Admin and HRMS managers only. No physical deletes; reject a candidate by
    // setting stage = 'rejected' with a rejectionReason.
    match /candidates/{docId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── HRMS: Training Programs ──────────────────────────────────────────────
    // Admin-managed catalog of training programs (AMFI, IRDA, NCFM, POSH, etc.)
    match /training_programs/{docId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── HRMS: Training Records ───────────────────────────────────────────────
    // Per-employee enrollment and completion tracking.
    // Employees may read their own records; only admin/HR may create or update.
    match /training_records/{docId} {
      allow read:   if isAdmin() || isHrmsManager()
                    || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create,
            update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── HRMS: Salary History ────────────────────────────────────────────────
    // Confidential — admin and HRMS managers only. No self-service reads.
    // No physical deletes; corrections are recorded as new revision entries.
    match /salary_history/{docId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create: if isAdmin() || isHrmsManager();
      allow update: if false;   // salary history is immutable — add a correction entry instead
      allow delete: if false;
    }

    // ─── HRMS: HR Helpdesk / Grievance Tickets ───────────────────────────────
    // Employees may read and create their own tickets.
    // Admin and HRMS managers may read all tickets and update (respond/close).
    // Anonymous tickets: employeeId is still stored for audit; isAnonymous flag
    // controls display. Admin can see all regardless of isAnonymous.
    // No physical deletes — tickets form a permanent audit trail.
    match /hr_tickets/{docId} {
      allow read:   if isAdmin() || isHrmsManager()
                    || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.employeeId == request.auth.uid;
      allow update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── Document Acknowledgements ────────────────────────────────────────────
    // Immutable digital sign-off records. Employees create their own; once written
    // they cannot be changed or deleted — they are a permanent compliance record.
    // Admins and HRMS managers can read all acknowledgements (for compliance reporting).
    match /document_acknowledgements/{ackId} {
      // Employees can read their own acks; admins/managers can read all.
      allow read: if isAdmin() || isHrmsManager()
                  || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      // Employees can only create an ack for themselves.
      allow create: if isSignedIn()
                    && request.resource.data.employeeId == request.auth.uid
                    && request.resource.data.keys().hasAll(['documentId', 'documentTitle', 'employeeId', 'employeeName', 'acknowledgedAt', 'method'])
                    && request.resource.data.method == 'checkbox';
      // Immutable — no updates, no deletes.
      allow update: if false;
      allow delete: if false;
    }

    // ─── Comp Off Credits ─────────────────────────────────────────────────────
    // Admin-written record of comp off days granted to employees who worked on
    // Sundays or public holidays. Employees can read their own credits.
    // Immutable audit trail — no updates or deletes once written.
    match /comp_off_credits/{creditId} {
      allow read: if isAdmin() || isHrmsManager()
                  || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isAdmin() || isHrmsManager();
      allow update: if false;
      allow delete: if false;
    }

    // ─── Leave Year-End Reset records ────────────────────────────────────────
    // Written by admin or Cloud Scheduler (server endpoint). One doc per FY year.
    // Immutable once created — acts as a "done" flag for the year-end reset.
    match /leave_year_resets/{year} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create: if isAdmin() || isHrmsManager();
      allow update: if false;
      allow delete: if false;
    }

    // ─── Leave Encashment Requests ────────────────────────────────────────────
    // Employees submit requests; admin/HR manager approves.
    match /leave_encashment_requests/{docId} {
      allow read:   if isAdmin() || isHrmsManager()
                    || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.employeeId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.leaveDays is number
                    && request.resource.data.leaveDays >= 1
                    && request.resource.data.leaveDays <= 30;
      allow update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── Generated HR Letters ─────────────────────────────────────────────────
    // Written by admin when generating a letter. Employees can read their own.
    match /generated_letters/{letterId} {
      allow read:   if isAdmin() || isHrmsManager()
                    || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isAdmin() || isHrmsManager();
      allow update: if false;   // letters are immutable — generate a new revision instead
      allow delete: if false;
    }

    // ─── Attendance Regularization Requests ──────────────────────────────────
    // Employee submits → status: pending. Admin approves or rejects.
    // Create: employee for their own records only.
    // Read:   employee reads own; admin/HR reads all.
    // Update: admin/HR only (to approve/reject).
    // Delete: never.
    match /attendance_regularizations/{reqId} {
      allow read:   if isAdmin() || isHrmsManager()
                    || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.employeeId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() > 0
                    && request.resource.data.reason.size() <= 2000
                    && request.resource.data.date is string
                    && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
      allow update: if isAdmin() || isHrmsManager();
      allow delete: if false;
    }

    // ─── Profile Update Logs ──────────────────────────────────────────────────
    // Immutable audit log when employees update their own contact/emergency details.
    match /profile_update_logs/{logId} {
      allow read:   if isAdmin() || isHrmsManager();
      allow create: if isSignedIn()
                    && request.resource.data.employeeId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ─── In-App Notifications ─────────────────────────────────────────────────
    // /notifications/{uid}/items/{itemId}
    //
    // Read: only the notification's owner (uid == request.auth.uid).
    // Create: admin, isHrmsManager, or any signed-in user (for CRM webhook-written notifs).
    //         Server-side Admin SDK writes always bypass rules (new_lead from processInboundLead).
    //         Client-side writes come from admin pages (leave approve, claim approve, etc.).
    // Update: only the owner — to mark notifications as read (read: true).
    //         Strictly limited: only the `read` field may change.
    // Delete: never — notifications are permanent for audit purposes.
    match /notifications/{uid}/items/{itemId} {
      allow read:   if isSignedIn() && request.auth.uid == uid;
      allow create: if isAdmin() || isHrmsManager();
      allow update: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
                    && request.resource.data.read == true;
      allow delete: if false;
    }

    // ─── CRM: Document Vault ─────────────────────────────────────────────────
    // Opportunity-level file attachments (bank statements, ITR scans, ID proof…).
    // Writes go through POST /api/crm/documents/upload (Admin SDK) — write: false.
    // Soft-delete (deleted: true) allowed by the owner or admin.
    // No hard deletes — permanent audit trail.
    match /crm_documents/{docId} {
      allow read:   if isAdmin() || hasCrmAccess();
      allow create: if isAdmin() || hasCrmAccess();
      // Only allow soft-deletes — only `deleted`, `deletedAt`, `deletedBy` may change.
      allow update: if (isAdmin() || (hasCrmAccess() && resource.data.uploadedBy == request.auth.uid))
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['deleted', 'deletedAt', 'deletedBy'])
                    && request.resource.data.deleted == true;
      allow delete: if false;
    }

    // ─── Performance & Targets (Phase N) ─────────────────────────────────────────
    // RM targets per month. RMs read their own; managers/admin read all + write.
    match /rm_targets/{docId} {
      // Targets are not PII — any signed-in employee may read (fixes the own-badge
      // permission-denied on a non-existent target doc). Writes stay admin/manager only.
      allow read:   if isSignedIn();
      allow create, update: if isAdmin() || isManager();
      allow delete: if false;
    }

    // Follow-up reminder logs — written by the server (Admin SDK only); admin read.
    match /follow_up_logs/{logId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // RM scorecard generation logs — written by the server (Admin SDK only); admin read.
    match /scorecard_logs/{logId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // CRM 2.0 payout-reminder idempotency markers — server (Admin SDK) only; admin read.
    match /crm2_reminder_logs/{logId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Bank commission-statement parsing templates (MIS). Admin-managed.
    match /commission_statement_templates/{bankId} {
      allow read:   if isAdmin() || hasMisAccess();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══ Phase P — Page Sharing / Super Admin Log / Presence / Disputes /
    //              Field History ═══════════════════════════════════════════════

    // Page shares — exception grants of single pages, created/revoked by super
    // admins only (hardcoded list; a UI-promoted SA needs the printed manual
    // rules edit before they can share). Permanent until revoked; no deletes.
    match /page_shares/{shareId} {
      allow read:   if isSuperAdminUid() ||
                       (isSignedIn() && request.auth.uid == resource.data.grantedTo);
      allow create: if isSuperAdminUid();
      allow update: if isSuperAdminUid() &&
                       incoming().diff(existing()).affectedKeys().hasOnly([
                         'active', 'revokedAt', 'revokedBy', 'revokedByName'
                       ]);
      allow delete: if false;
    }

    // Super-admin promotion/demotion audit — append-only, SA-only.
    match /super_admin_log/{logId} {
      allow read:   if isSuperAdminUid();
      allow create: if isSuperAdminUid();
      allow update, delete: if false;
    }

    // Real-time presence — ephemeral "who's viewing this page". Each user may
    // only write their own viewer doc; anyone signed in can see viewers.
    match /presence/{pageKey}/viewers/{uid} {
      allow read:   if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.uid == uid;
    }

    // Commission disputes — variance disputes with providers (MIS).
    match /commission_disputes/{disputeId} {
      allow read:   if isAdmin() || hasMisAccess();
      allow create: if isAdmin() || isMisAdmin();
      allow update: if isAdmin() || hasMisAccess();
      allow delete: if false;
    }

    // Field history — per-field audit diffs written in the SAME batch as the
    // parent update. Append-only; admin/manager read.
    match /leads/{leadId}/field_history/{fieldName}/changes/{changeId} {
      allow read:   if isAdmin() || isManager();
      allow create: if isSignedIn() && incoming().changedBy == request.auth.uid;
      allow update, delete: if false;
    }
    match /leads/{leadId}/opportunities/{oppId}/field_history/{fieldName}/changes/{changeId} {
      allow read:   if isAdmin() || isManager();
      allow create: if isSignedIn() && incoming().changedBy == request.auth.uid;
      allow update, delete: if false;
    }
    match /leads/{leadId}/opportunities/{oppId}/bank_submissions/{subId}/field_history/{fieldName}/changes/{changeId} {
      allow read:   if isAdmin() || isManager();
      allow create: if isSignedIn() && incoming().changedBy == request.auth.uid;
      allow update, delete: if false;
    }
    match /commission_records/{recordId}/field_history/{fieldName}/changes/{changeId} {
      allow read:   if isAdmin() || isManager();
      allow create: if isSignedIn() && incoming().changedBy == request.auth.uid;
      allow update, delete: if false;
    }
    match /users/{userId}/field_history/{fieldName}/changes/{changeId} {
      allow read:   if isAdmin() || isManager();
      allow create: if isSignedIn() && incoming().changedBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ═══ CRM 2.0 / Pipeline (PLAN.md) ═══════════════════════════════════════════
    // ALL mutations go through Express (Admin SDK bypasses rules) — every client
    // write below is denied. Reads are gated by the Pipeline permission keys.

    // Masters — names/config needed by pickers across the module.
    match /lenders/{lenderId} {
      allow read:  if isAdmin() || hasAnyCrm2Read();
      allow write: if false;   // server-only via /api/crm2/masters
    }
    match /products/{productId} {
      allow read:  if isAdmin() || hasAnyCrm2Read();
      allow write: if false;
    }
    // Sub-products (just names) mapped to a product — see SubProduct master.
    match /subProducts/{subProductId} {
      allow read:  if isAdmin() || hasAnyCrm2Read();
      allow write: if false;
    }
    // Upstream aggregators (spec "connectors" — renamed collection, PLAN.md decision 1).
    match /aggregators/{aggregatorId} {
      allow read:  if isAdmin() || hasAnyCrm2Read();
      allow write: if false;
    }
    match /documentMaster/{docId} {
      allow read:  if isAdmin() || hasAnyCrm2Read();
      allow write: if false;
    }
    // Sub-DSAs — bank account + PAN stored encrypted (EncryptedField objects);
    // last-4 display fields are safe for module readers.
    match /subDsas/{subDsaId} {
      allow read:  if isAdmin() || hasAnyCrm2Read();
      allow write: if false;
    }
    // THE PAYOUT ENGINE — slab percentages are money data: payout.amounts.read only.
    match /dsaCodeMappings/{mappingId} {
      allow read:  if isAdmin() || hasCrm2Perm('payout.amounts.read');
      allow write: if false;
    }
    // ID counters — server-only in both directions.
    match /counters/{counterId} {
      allow read, write: if false;
    }

    // Clients (Phase 2 convert output). PAN encrypted; last4 safe for readers.
    match /clients/{clientId} {
      allow read:  if isAdmin() || hasCrm2Perm('crm.leads.read') || hasCrm2Perm('crm.cases.read');
      allow write: if false;   // server-only (convert + Phase 3 client CRUD)

      match /vaultDocs/{vaultDocId} {
        allow read:  if isAdmin() || hasCrm2Perm('crm.cases.read');
        allow write: if false;
      }
    }

    // Cases + subcollections (created by convert; full CRUD lands in Phase 3).
    // The money mirror is doc-split into private/payout (PLAN.md decision 2).
    match /cases/{caseId} {
      allow read:  if isAdmin() || hasCrm2Perm('crm.cases.read');
      allow write: if false;

      match /private/{docId} {
        allow read:  if isAdmin() || hasCrm2Perm('payout.amounts.read');
        allow write: if false;
      }
      match /applicants/{applicantId} {
        allow read:  if isAdmin() || hasCrm2Perm('crm.cases.read');
        allow write: if false;
      }
      match /docTracker/{rowId} {
        allow read:  if isAdmin() || hasCrm2Perm('crm.cases.read');
        allow write: if false;
      }
      match /stageHistory/{entryId} {
        allow read:  if isAdmin() || hasCrm2Perm('crm.cases.read');
        allow write: if false;
      }
      // Phase 4 — per-login pipeline. The login doc itself carries no money
      // (sanction figures are operational; payout economics live in the cycle/
      // mirror, gated separately). Server-only writes.
      match /logins/{loginId} {
        allow read:  if isAdmin() || hasCrm2Perm('crm.cases.read');
        allow write: if false;
      }
      // Phase 6 — case collaboration thread (tasks + updates). Server-only writes.
      match /tasks/{taskId} {
        allow read:  if isAdmin() || hasCrm2Perm('crm.cases.read');
        allow write: if false;
      }
    }

    // ─── Phase 4 — Payout cycles + MIS projection ────────────────────────────
    // Both docs carry money, so direct SDK reads require payout.amounts.read.
    // payout.read / mis.read users get money-STRIPPED data via the Express APIs
    // (GET /api/crm2/payout-cycles[/:id], /api/crm2/mis) which run through the
    // Admin SDK. All client writes denied — mutations only via disburse/milestone.
    match /payoutCycles/{cycleId} {
      allow read:  if isAdmin() || hasCrm2Perm('payout.amounts.read');
      allow write: if false;
    }
    match /misRecords/{caseId} {
      allow read:  if isAdmin() || hasCrm2Perm('payout.amounts.read');
      allow write: if false;
    }

    // ─── Phase 5 — Reconciliation + snapshots ────────────────────────────────
    // The import DOC is metadata (counts/filename) → recon.read. The ROWS carry
    // the dump amounts (money) — a direct SDK read therefore requires
    // payout.amounts.read; recon.read users get money-STRIPPED rows via
    // GET /api/crm2/recon/imports/:id (Admin SDK). All client writes denied
    // (import/match/unmatch via Express).
    match /bankMisImports/{importId} {
      allow read:  if isAdmin() || hasCrm2Perm('recon.read');
      allow write: if false;

      match /rows/{rowId} {
        allow read:  if isAdmin() || hasCrm2Perm('payout.amounts.read');
        allow write: if false;
      }
    }
    // Monthly recon snapshots contain money totals → payout.amounts.read.
    match /reconSnapshots/{snapId} {
      allow read:  if isAdmin() || hasCrm2Perm('payout.amounts.read');
      allow write: if false;
    }
  }
}
