# VITE_USE_EMULATOR: Set to "true" to connect to local Firebase emulators.
# Used automatically by `npm run dev:emulator`. Do not set in production.
VITE_USE_EMULATOR="false"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google OAuth Credentials
# Obtain these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Google Workspace SMTP (nodemailer) — for new-device login alerts and support ticket notifications.
# SMTP_USER:         Your finvastra.com Google Workspace email address used as the sender.
# SMTP_APP_PASSWORD: A 16-character Google App Password (not your account password).
#   Generate at: https://myaccount.google.com/apppasswords  (2FA must be enabled)
SMTP_USER="sender@finvastra.com"
SMTP_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Webhook Secrets — required before enabling website form or Meta Lead Ads integration.
# Set in Cloud Run via:
#   gcloud run services update pulse-api \
#     --set-env-vars "WEBSITE_WEBHOOK_SECRET=xxx,META_WEBHOOK_SECRET=xxx" \
#     --region asia-south1
#
# WEBSITE_WEBHOOK_SECRET: Any strong random secret (≥32 chars).
#   The website must send this in the X-Finvastra-Webhook-Secret header on every POST.
# META_WEBHOOK_SECRET: (LEGACY — the old /api/leads/intake/meta handler). Superseded by
#   the three META_* vars below for the new /api/webhooks/meta/leadgen integration.
WEBSITE_WEBHOOK_SECRET=your-strong-secret-here
META_WEBHOOK_SECRET=your-meta-verify-token

# ─── Meta Lead Ads → CRM 2.0 webhook (/api/webhooks/meta/leadgen) ─────────────────
# Three SEPARATE values — do not reuse one for all three. Read from env ONLY; never
# commit real values. Set in Cloud Run:
#   gcloud run services update pulse-api --region asia-south1 --update-env-vars \
#     "META_VERIFY_TOKEN=xxx,META_APP_SECRET=xxx,META_PAGE_ACCESS_TOKEN=xxx,META_GRAPH_VERSION=v23.0"
#
# META_VERIFY_TOKEN: Arbitrary string you also type into the Meta webhook setup UI.
#   Echoed back during the GET subscription handshake (hub.verify_token). NOT a secret
#   in the cryptographic sense, but keep it private.
# META_APP_SECRET: The Meta App's "App Secret" (App Dashboard → Settings → Basic).
#   Used to HMAC-verify X-Hub-Signature-256 on every POST. THE security boundary.
# META_PAGE_ACCESS_TOKEN: A LONG-LIVED System User token with leads_retrieval +
#   pages_manage_metadata on the Page. Used to pull the lead via the Graph API.
#   (A standard 60-day Page token will expire — use a System User token.)
# META_GRAPH_VERSION: Graph API version for the lead pull (e.g. v23.0). Pin + bump
#   deliberately; do not leave to an implicit default.
META_VERIFY_TOKEN=your-meta-verify-token
META_APP_SECRET=your-meta-app-secret
META_PAGE_ACCESS_TOKEN=your-long-lived-system-user-token
META_GRAPH_VERSION=v23.0

# Super Admin UIDs — comma-separated Firebase Auth UIDs for the three platform owners.
# These accounts cannot be deactivated or have their roles changed by non-super-admins.
# Enforced in server.ts (deactivate / sync-claims endpoints) and firestore.rules.
# Values are stable Firebase Auth UIDs — never change without updating firestore.rules too.
SUPER_ADMIN_UIDS="3zdX5QBnTbQAcTdLzUjfXxefP8r2,ZmZaciATPDYBb1O2blYWBjjbzMv1,5lAbJ4CZ5uM0LbU4gUYItNRAlEn2"
